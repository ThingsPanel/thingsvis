{
  "name": "thingsvis",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "turbo run dev --filter=studio --filter=@thingsvis/server",
    "build": "turbo run build",
    "build:plugins": "turbo run build --filter=\"thingsvis-plugin-*\"",
    "dev:plugins": "turbo run dev --filter=\"thingsvis-plugin-*\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "vis-cli": "pnpm --filter vis-cli build && node tools/cli/dist/index.js"
  },
  "devDependencies": {
    "@module-federation/enhanced": "^0.6.0",
    "@module-federation/rspack": "^0.6.0",
    "@playwright/test": "^1.58.0",
    "@rspack/cli": "^1.0.0",
    "@rspack/core": "^1.0.0",
    "@types/node": "^20.10.6",
    "playwright": "^1.58.0",
    "turbo": "^1.12.3",
    "typescript": "^5.3.3",
    "vis-cli": "workspace:*"
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "zustand": "^4.5.0"
  }
}