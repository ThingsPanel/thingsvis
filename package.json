{
  "name": "ThingsVis",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "turbo run dev --filter=studio --filter=@thingsvis/server",
    "build": "turbo run build",
    "build:widgets": "turbo run build --filter=\"thingsvis-widget-*\" && pnpm run deploy:widgets",
    "deploy:widgets": "node -e \"const fs=require('fs'),path=require('path');['basic','chart','media','indicator'].forEach(cat=>{const d='widgets/'+cat;if(!fs.existsSync(d))return;fs.readdirSync(d).forEach(w=>{const s='widgets/'+cat+'/'+w+'/dist',t='apps/studio/public/widgets/'+cat+'/'+w+'/dist';if(!fs.existsSync(s))return;if(fs.existsSync(t)&&!fs.statSync(t).isDirectory()){fs.unlinkSync(t);}fs.mkdirSync(t,{recursive:true});fs.readdirSync(s).forEach(f=>{const sp=path.join(s,f),tp=path.join(t,f);try{if(fs.statSync(sp).isFile())fs.copyFileSync(sp,tp);}catch(e){}});console.log('deployed:',cat+'/'+w);});});\"",
    "dev:widgets": "turbo run dev --filter=\"thingsvis-widget-*\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "vis-cli": "pnpm --filter vis-cli build && node tools/cli/dist/index.js"
  },
  "devDependencies": {
    "@module-federation/enhanced": "^0.6.0",
    "@module-federation/rspack": "^0.6.0",
    "@playwright/test": "^1.58.0",
    "@rspack/cli": "^1.0.0",
    "@rspack/core": "^1.0.0",
    "@types/node": "^20.10.6",
    "playwright": "^1.58.0",
    "turbo": "^1.12.3",
    "typescript": "^5.3.3",
    "vis-cli": "workspace:*"
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "zustand": "^4.5.0"
  }
}