{
    "name": "{{PACKAGE_NAME}}",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "dev": "rspack serve --port {{DEV_SERVER_PORT}}",
        "build": "rspack build",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "peerDependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "@thingsvis/schema": "workspace:*"
    },
    "dependencies": {
        "@thingsvis/widget-sdk": "workspace:*"
    },
    "devDependencies": {
        "@rspack/cli": "^1.0.0",
        "@rspack/core": "^1.0.0",
        "typescript": "^5.3.3",
        "ts-loader": "^9.5.1",
        "@types/react": "^18.2.41",
        "@types/react-dom": "^18.2.17",
        "@thingsvis/widget-config": "workspace:*"
    },
    "thingsvis": {
        "displayName": "{{DISPLAY_NAME}}",
        "icon": "Box",
        "i18n": {
            "zh": "{{DISPLAY_NAME}}",
            "en": "{{COMPONENT_ID}}"
        }
    }
}