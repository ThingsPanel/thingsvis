# ============================================================
# ThingsVis Server Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp apps/server/.env.example apps/server/.env
# ============================================================

# ─── Database ────────────────────────────────────────────────
# SQLite (default for local development — zero setup required)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (recommended for production)
# DATABASE_URL="postgresql://thingsvis:thingsvis_password@localhost:5432/thingsvis_db?schema=public"

# ─── Authentication ─────────────────────────────────────────
# Generate a secure secret for production: openssl rand -base64 32
AUTH_SECRET="thingsvis-dev-secret-key"

# Public-facing URL of the application (used for OAuth callbacks)
AUTH_URL="http://localhost:3000"

# Trust the host header (required when behind a proxy)
AUTH_TRUST_HOST=true

# ─── Server ─────────────────────────────────────────────────
# Port the API server listens on
PORT=8000

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# Example: http://your-domain.com,http://another-domain.com
ALLOWED_ORIGINS=

# ─── Seed (optional) ────────────────────────────────────────
# Override default admin credentials for the seed script
# SEED_ADMIN_EMAIL=admin@thingsvis.io
# SEED_ADMIN_PASSWORD=admin123
# SEED_ADMIN_NAME=Admin
