# ============================================================
# ThingsVis Server Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp apps/server/.env.example .env
# ============================================================

# ─── Database ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/thingsvis"

# ─── Authentication ────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_A_SECRET"

# Public-facing URL of the application (used for OAuth callbacks)
AUTH_URL="http://localhost:3000"

# ─── Server ────────────────────────────────────────────────
# Port the API server listens on
PORT=8000

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# Leave empty to use defaults: localhost:3000, localhost:8000, localhost:5173
# Example: http://your-domain.com,http://another-domain.com
ALLOWED_ORIGINS=

# ─── Seed (optional) ──────────────────────────────────────
# Override default admin credentials for the seed script
# SEED_ADMIN_EMAIL=admin@thingsvis.io
# SEED_ADMIN_PASSWORD=admin123
# SEED_ADMIN_NAME=Admin
