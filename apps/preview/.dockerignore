# Docker ignore文件
# 构建时忽略这些文件

# Node modules
node_modules/
**/node_modules/

# Build output
dist/
build/
.next/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env*
!.env.production.example

# IDE
.idea/
.vscode/
*.swp
*.swo
*.swn
.DS_Store

# Git
.git/
.gitignore

# Testing
coverage/
.nyc_output/

# Misc
*.md
!DEPLOYMENT.md
.editorconfig
